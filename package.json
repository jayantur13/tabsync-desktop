{
  "name": "tabsync-desktop",
  "version": "1.0.0",
  "description": "Sync your browser tabs across devices with a local server and desktop UI.",
  "main": "main.js",
  "type": "module",
  "author": {
    "name": "Jayant Navrange",
    "email": "vu.vcareforu@gmail.com"
  },
  "productName": "TabSync",
  "license": "MIT",
  "homepage": "https://github.com/jayantur13/tabsync-desktop#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/jayantur13/tabsync-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/jayantur13/tabsync-desktop/issues"
  },
  "keywords": [
    "electron",
    "tabsync",
    "browser-sync",
    "local-server",
    "cross-device",
    "tray-app",
    "utility"
  ],
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "publish": "electron-forge publish",
    "make:linux": "electron-forge make --platform=linux --arch=x64",
    "make:win": "electron-forge make --platform=win32 --arch=x64",
    "make:clean": "rm -rf out/make out/TabSync-*",
    "make:all": "npm run make:clean && npm run make:linux && npm run make:win",
    "release": "node scripts/release.js"
  },
  "dependencies": {
    "auto-launch": "^5.0.6",
    "dotenv": "^17.4.2",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9"
  },
  "overrides": {
    "tar": "7.5.16",
    "tmp": "0.2.7"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron/fuses": "^1.0.0",
    "@forkprince/electron-forge-maker-appimage": "^1.0.2",
    "@octokit/rest": "^22.0.1",
    "electron": "^42.4.1",
    "prompts": "^2.4.2",
    "simple-git": "^3.36.0"
  },
  "config": {
    "forge": "forge.config.cjs"
  }
}
